{
  "name": "supporter-product-data-typescript",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "jest --group=-integration",
    "it-test": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest --group=integration",
    "lint": "eslint src/typescript/**/*.ts cdk/**/*.ts",
    "lint:fix": "eslint --fix src/typescript/**/*.ts cdk/**/*.ts",
    "check-formatting": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "fix-formatting": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "build": "tsc --noEmit",
    "bundle": "node esbuild.config.mjs",
    "clean-target": "rm -rf target && mkdir -p target/typescript",
    "zip": "cd target/typescript && zip -r supporter-product-data-typescript.zip ./* -x \".*\" -x \"__MACOSX\"",
    "bundle-and-zip": "pnpm clean-target && pnpm bundle && pnpm zip",
    "cdk:build": "tsc -p cdk/tsconfig.json",
    "cdk:synth": "pnpm cdk:build && cdk synth --app \"node cdk/dist/bin/cdk.js\" --output cdk/cdk.out --path-metadata false --version-reporting false",
    "package": "pnpm check-formatting && pnpm build && pnpm test && pnpm bundle-and-zip && pnpm cdk:synth",
    "run:local": "tsx src/typescript/local/runQueryZuora.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "catalog:",
    "@aws-sdk/client-dynamodb": "^3.995.0",
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/client-sqs": "catalog:",
    "@aws-sdk/client-ssm": "catalog:",
    "@aws-sdk/credential-provider-node": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@guardian/prettier": "catalog:",
    "@types/aws-lambda": "^8.10.147",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "aws-cdk": "2.1007.0",
    "aws-cdk-lib": "2.189.1",
    "constructs": "10.4.2",
    "esbuild": "catalog:",
    "esbuild-ts-paths": "^1.1.3",
    "eslint": "^9.38.0",
    "jest": "catalog:",
    "jest-runner-groups": "catalog:",
    "prettier": "catalog:",
    "ts-jest": "catalog:",
    "tsx": "^4.20.6",
    "typescript": "catalog:"
  }
}
